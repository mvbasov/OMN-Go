<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" >
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <!--
      Background-server support (ServerService). FOREGROUND_SERVICE covers
      API 28+; FOREGROUND_SERVICE_DATA_SYNC is the typed companion required
      by targetSdk 34 for the dataSync service type declared below.
      POST_NOTIFICATIONS (runtime-requested on Android 13+) makes the
      service's persistent notification visible. The battery-optimization
      exemption (requested once from MainActivity) keeps network alive in
      deep Doze while the screen is locked; note this permission is
      restricted on Google Play but fine for self-distributed APKs.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!--
      Android 11+ (API 30+) hides other apps' components by default
      (package visibility). MainActivity's shouldOverrideUrlLoading hands
      off non-http(s) links (tel:, geo:, mailto:, sms:, market:, intent://,
      ...) to the OS via an implicit ACTION_VIEW intent (or
      Intent.parseUri for intent:// links). Without declaring those schemes
      here, resolveActivity()/startActivity() silently find nothing even
      when a matching app (Dialer, Maps, Email, Play Store...) is
      installed, which is what produced ERR_UNKNOWN_URL_SCHEME. Each entry
      below matches a scheme the WebView can actually hand off.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="tel" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="sms" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="smsto" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="mailto" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="market" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>
    </queries>

    <application
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="true"
        android:label="OMN-Go"
        android:usesCleartextTraffic="true"
        android:hardwareAccelerated="true"
        android:theme="@android:style/Theme.NoTitleBar.Fullscreen">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|keyboardHidden|screenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
                    <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <!--
              Shared images/JSON land in Quick Notes, not the editor - see
              the block comment above MainActivity.handleSharedFile() for
              why. Two filters (Android matches SEND by declared mime type,
              not actual content) rather than one combined filter, mirroring
              the text/plain filter above; only image/* and
              application/json are advertised, matching the "only images
              and JSON accepted" whitelist saveUploadedFile enforces
              server-side (backend/handlers.go).
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/json" />
            </intent-filter>
        </activity>

        <!--
          Owns the Go HTTP server (see ServerService.java). stopWithTask=
          "false" keeps the server answering even after the user swipes
          the app out of recents - the notification's Stop button is the
          intended way to shut it down.
        -->
        <service
            android:name=".ServerService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
