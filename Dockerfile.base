# STAGE 1: Toolchains & Cache
FROM golang:1.26-bookworm AS base_env

ENV DEBIAN_FRONTEND=noninteractive

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y \
    openjdk-17-jdk wget unzip cmake ninja-build

# Install Android CMD Line Tools
RUN --mount=type=cache,target=/tmp/dl,sharing=locked \
    wget -q https://dl.google.com/android/repository/commandlinetools-linux-10406996_latest.zip -O /tmp/dl/cmd.zip && \
    mkdir -p /opt/android/cmdline-tools && \
    unzip -q /tmp/dl/cmd.zip -d /opt/android/cmdline-tools && \
    mv /opt/android/cmdline-tools/cmdline-tools /opt/android/cmdline-tools/latest

ENV ANDROID_HOME=/opt/android
ENV PATH=$PATH:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools

RUN --mount=type=cache,target=/opt/android/.android/cache,sharing=locked \
    yes | sdkmanager --licenses && \
    sdkmanager "platforms;android-34" "build-tools;33.0.1" "platform-tools" "ndk;25.2.9519653"

# Install Gradle
RUN --mount=type=cache,target=/tmp/dl,sharing=locked \
    wget -q https://services.gradle.org/distributions/gradle-8.5-bin.zip -O /tmp/dl/gradle.zip && \
    mkdir -p /opt/gradle && \
    unzip -q /tmp/dl/gradle.zip -d /opt/gradle
ENV PATH=$PATH:/opt/gradle/gradle-8.5/bin

WORKDIR /app

# The host has no Go toolchain, so go.sum can only be generated here,
# inside the container - once, whenever go.mod changes. golang.org/x/mobile
# isn't in the committed go.mod either (nothing on the host could have
# added it), so it's added here as a `tool` dependency, matching stage 2's
# `go mod tidy` expectations.
#
# The result is stashed under /root/lockfiles - NOT under /app - so that
# stage 2's later `COPY . .` (which brings in the host's incomplete,
# go.sum-less go.mod) can't overwrite it. Stage 2 restores it explicitly
# instead. (Earlier revisions tried to solve this with a second
# .dockerignore file to exclude go.mod/go.sum from stage 2's COPY - that
# works but is fragile: BuildKit's per-Dockerfile ignore file REPLACES the
# root .dockerignore rather than merging with it, so it silently drops
# every other exclusion too unless kept in careful sync by hand. This
# stash-and-restore approach needs no ignore-file trickery at all.)
COPY go.mod ./
RUN --mount=type=cache,target=/go/pkg/mod,sharing=locked \
    go get -tool golang.org/x/mobile/cmd/gobind golang.org/x/mobile/cmd/gomobile && \
    go mod download && \
    go install golang.org/x/mobile/cmd/gobind && \
    go install golang.org/x/mobile/cmd/gomobile && \
    gomobile init && \
    mkdir -p /root/lockfiles && cp go.mod go.sum /root/lockfiles/
